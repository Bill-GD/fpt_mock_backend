generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String
  password  String   @db.Char(60)
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  exams         Exam[]         @relation("teacher_exams")
  rooms         Room[]         @relation("teacher_rooms")
  attempts      Attempt[]      @relation("student_attempts")
  violationLogs ViolationLog[] @relation("student_violation_logs")

  @@map("users")
}

model Exam {
  id              Int      @id @default(autoincrement())
  teacher         User     @relation("teacher_exams", fields: [teacherId], references: [id])
  teacherId       Int      @map("teacher_id")
  title           String
  description     String?  @db.Text
  durationMinutes Int      @map("duration_minutes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  questions Question[]
  rooms     Room[]

  @@map("exams")
}

model Question {
  id      Int    @id @default(autoincrement())
  exam    Exam   @relation(fields: [examId], references: [id])
  examId  Int    @map("exam_id")
  content String @db.Text

  options Option[]
  answers Answer[]

  @@map("questions")
}

model Option {
  id         Int      @id @default(autoincrement())
  question   Question @relation(fields: [questionId], references: [id])
  questionId Int      @map("question_id")
  content    String   @db.Text
  isCorrect  Boolean  @map("is_correct")

  answers Answer[]

  @@map("options")
}

model Room {
  id        Int        @id @default(autoincrement())
  exam      Exam       @relation(fields: [examId], references: [id])
  examId    Int        @map("exam_id")
  teacher   User       @relation("teacher_rooms", fields: [teacherId], references: [id])
  teacherId Int        @map("teacher_id")
  startedAt DateTime   @map("started_at")
  code      String     @unique @db.VarChar(8)
  status    RoomStatus @default(INACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")

  attempts Attempt[]

  @@map("rooms")
}

model Attempt {
  id           Int       @id @default(autoincrement())
  room         Room      @relation(fields: [roomId], references: [id])
  roomId       Int       @map("room_id")
  student      User      @relation("student_attempts", fields: [studentId], references: [id])
  studentId    Int       @map("student_id")
  submittedAt  DateTime? @map("submitted_at")
  correctCount Int       @default(0) @map("correct_count")
  score        Int       @default(0)

  answers    Answer[]
  violations ViolationLog[]

  @@map("attempts")
}

model Answer {
  id               Int      @id @default(autoincrement())
  attempt          Attempt  @relation(fields: [attemptId], references: [id])
  attemptId        Int      @map("attempt_id")
  question         Question @relation(fields: [questionId], references: [id])
  questionId       Int      @map("question_id")
  selectedOption   Option?  @relation(fields: [selectedOptionId], references: [id])
  selectedOptionId Int?     @map("selected_option_id")

  @@map("answers")
}

model ViolationLog {
  id            Int           @id @default(autoincrement())
  attempt       Attempt       @relation(fields: [attemptId], references: [id])
  attemptId     Int           @map("attempt_id")
  student       User          @relation("student_violation_logs", fields: [studentId], references: [id])
  studentId     Int           @map("student_id")
  violationType ViolationType @map("violation_type")
  evidenceUrl   String?       @map("evidence_url")
  timestamp     DateTime

  @@map("violation_logs")
}

enum UserRole {
  TEACHER @map("teacher")
  STUDENT @map("student")

  @@map("user_role_enum")
}

enum RoomStatus {
  INACTIVE @map("inactive")
  WAITING  @map("waiting")
  ACTIVE   @map("active")
  FINISHED @map("finished")

  @@map("room_status_enum")
}

enum ViolationType {
  TAB_SWITCH            @map("tab_switch")
  KEYBOARD_COPY         @map("keyboard_copy")
  KEYBOARD_PASTE        @map("keyboard_paste")
  CAMERA_MULTIPLE_FACES @map("camera_multiple_faces")
  CAMERA_GAZE_AWAY      @map("camera_gaze_away")
  CAMERA_MISSING        @map("camera_missing")

  @@map("violation_type_enum")
}
